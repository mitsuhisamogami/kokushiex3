<header class="border-b border-blue-100 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-7xl flex-col gap-3 px-4 py-3 sm:px-6 lg:h-16 lg:flex-row lg:items-center lg:justify-between lg:gap-6 lg:py-0">
    <%= link_to root_path, class: 'flex items-center gap-3 text-blue-900' do %>
      <%= image_tag 'logo.png', class: 'h-10 w-10 shrink-0' %>
      <span class="text-xl font-bold tracking-normal">国試ex for PT</span>
    <% end %>

    <nav class="flex flex-wrap items-center gap-x-2 gap-y-3 text-sm font-bold text-slate-700 lg:justify-end">
      <%= link_to 'トップ',
                  root_path,
                  class: 'rounded-lg px-3 py-2 transition hover:bg-blue-50 hover:text-blue-800' %>
      <%= link_to 'ダッシュボード',
                  dashboard_path,
                  class: 'rounded-lg px-3 py-2 transition hover:bg-blue-50 hover:text-blue-800' %>
      <%= link_to '過去問演習',
                  tests_select_path,
                  class: 'rounded-lg px-3 py-2 transition hover:bg-blue-50 hover:text-blue-800' %>

      <% if user_signed_in? %>
        <%= link_to 'マイページ',
                    account_path,
                    class: 'inline-flex items-center justify-center rounded-lg bg-blue-700 px-4 py-2 ' \
                           'text-white shadow-sm shadow-blue-800/10 transition hover:bg-blue-800' %>

        <% if current_user.guest? %>
          <%= button_to 'ゲストログアウト',
                        users_guest_sign_out_path,
                        method: :delete,
                        data: { turbo_method: :delete },
                        class: 'rounded-lg px-3 py-2 font-bold text-slate-700 transition hover:bg-blue-50 ' \
                               'hover:text-blue-800' %>
        <% else %>
          <%= button_to 'ログアウト',
                        destroy_user_session_path,
                        method: :delete,
                        data: { turbo_method: :delete },
                        class: 'rounded-lg px-3 py-2 font-bold text-slate-700 transition hover:bg-blue-50 ' \
                               'hover:text-blue-800' %>
        <% end %>
      <% else %>
        <%= link_to 'ログイン',
                    new_user_session_path,
                    class: 'rounded-lg px-3 py-2 transition hover:bg-blue-50 hover:text-blue-800' %>
        <%= link_to 'ゲストログイン',
                    users_guest_sign_in_path,
                    data: { 'turbo-method': :post },
                    class: 'inline-flex items-center justify-center rounded-lg border border-blue-200 px-4 py-2 ' \
                           'text-blue-800 transition hover:border-blue-300 hover:bg-blue-50' %>
        <%= link_to '無料会員登録',
                    new_user_registration_path,
                    class: 'inline-flex items-center justify-center rounded-lg bg-blue-700 px-4 py-2 text-white ' \
                           'shadow-sm shadow-blue-800/10 transition hover:bg-blue-800' %>
      <% end %>
    </nav>
  </div>
</header>
