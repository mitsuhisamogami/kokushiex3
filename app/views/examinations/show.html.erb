<div class='flex flex-wrap body-font'>
    <div class='w-full max-w-5xl m-auto px-4'>
        <div data-controller="results-display" class='mb-10 mt-5'>
            <div class='mb-4 flex gap-2 border-b border-gray-200'>
                <button type='button' class='border-b-2 px-4 py-2 text-sm font-bold'
                        data-results-display-target='tab' data-panel='report'
                        data-action='results-display#switch'>
                    レポート
                </button>
                <button type='button' class='border-b-2 px-4 py-2 text-sm font-bold'
                        data-results-display-target='tab' data-panel='errata'
                        data-action='results-display#switch'>
                    正誤表
                </button>
            </div>

            <div data-results-display-target='report'>
                <!-- レポートセクション -->
                <div class='flex mb-8'>
                    <%= render 'shared/score_report_card',
                               title: 'レポート',
                               examination: @examination,
                               score: @score %>
                </div>

                <!-- 正答率 -->
                <div class='w-full overflow-hidden rounded-lg border border-gray-200 bg-white shadow-lg'>
                    <div class='m-5'>
                        <h2 class='font-bold text-lg'>分野別正答率</h2>
                        <%= render 'result_chart', tag_score_summary: @tag_score_summary %>
                    </div>
                </div>
            </div>

            <!-- 正誤表 -->
            <div data-results-display-target="errata" class='hidden w-full overflow-hidden rounded-lg border border-gray-200 bg-white shadow-lg'>
                <div class='m-5'>
                    <h2 class='font-bold text-lg'>正誤表</h2>
                    <div class='mt-4'>
                        <!-- テーブル表示 -->
                        <div class="grid grid-cols-4 gap-2">
                            <% 4.times do |col| %>
                                <%= render partial: 'question_table',
                                           locals: {
                                             questions: @questions.slice(col * 50, 50) || [],
                                             examination: @examination, test: @test
                                           } %>
                            <% end %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
